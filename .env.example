# GEMINI_API_KEY: Required for Gemini AI API calls.
# You can get a Gemini API key from Google AI Studio or Google Cloud.
# Provide the value in your host environment or a deployment secret manager.
GEMINI_API_KEY="your_api_key_here"

# Search_Term_Project: Used as a fallback or primary alias for Gemini keys.
Search_Term_Project="your_api_key_here"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:3000"
